{
    "name": "fanat98/laravel-task-orchestrator",
    "description": "Lightweight Laravel task orchestration dashboard with scheduling, dependencies and real-time monitoring",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Malsa\\TaskOrchestrator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Malsa\\TaskOrchestrator\\TaskOrchestratorServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "dragonmantank/cron-expression": "^3.4"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
